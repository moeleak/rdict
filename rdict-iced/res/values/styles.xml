<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="RdictThemeBase" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/rdict_system_bar</item>
        <item name="android:navigationBarColor">@color/rdict_system_bar</item>
        <item name="android:windowLightStatusBar">@bool/rdict_light_system_bars</item>
        <item name="android:windowLightNavigationBar">@bool/rdict_light_system_bars</item>
    </style>

    <style name="RdictTheme" parent="@style/RdictThemeBase" />
</resources>
