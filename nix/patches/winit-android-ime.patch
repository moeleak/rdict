+    fn handle_text_input_event<F>(
+        &mut self,
+        android_app: &AndroidApp,
+        state: &TextInputState,
+        callback: &mut F,
+    ) where
+        F: FnMut(event::Event<T>, &RootAEL),
+    {
+        if let Some(compose_region) = valid_text_span(&state.text, state.compose_region) {
+            let mut committed = String::new();
+            committed.push_str(&state.text[..compose_region.start]);
+            committed.push_str(&state.text[compose_region.end..]);
+
+            self.commit_android_ime_text(&committed, callback);
+
+            let preedit = state.text[compose_region.clone()].to_owned();
+            let selection =
+                preedit_selection(&state.text, state.selection, &compose_region);
+
+            self.dispatch_ime_event(event::Ime::Preedit(preedit, selection), callback);
+        } else {
+            self.dispatch_ime_event(event::Ime::Preedit(String::new(), None), callback);
+            self.commit_android_ime_text(&state.text, callback);
+
+            self.ime_text.clear();
+            android_app.set_text_input_state(TextInputState::default());
+        }
+    }
+
+    fn commit_android_ime_text<F>(&mut self, text: &str, callback: &mut F)
+    where
+        F: FnMut(event::Event<T>, &RootAEL),
+    {
+        if text == self.ime_text {
+            return;
+        }
+
+        let commit = text
+            .strip_prefix(&self.ime_text)
+            .filter(|suffix| !suffix.is_empty())
+            .unwrap_or(text);
+
+        if !commit.is_empty() {
+            self.dispatch_ime_event(event::Ime::Commit(commit.to_owned()), callback);
+        }
+
+        self.ime_text.clear();
+        self.ime_text.push_str(text);
+    }
+
+    fn dispatch_ime_event<F>(&self, ime: event::Ime, callback: &mut F)
+    where
+        F: FnMut(event::Event<T>, &RootAEL),
+    {
+        callback(
+            event::Event::WindowEvent {
+                window_id: window::WindowId(WindowId),
+                event: event::WindowEvent::Ime(ime),
+            },
+            self.window_target(),
+        );
+    }
+
+    fn handle_text_input_action<F>(&self, action: TextInputAction, callback: &mut F)
+    where
+        F: FnMut(event::Event<T>, &RootAEL),
+    {
+        if matches!(
+            action,
+            TextInputAction::Go
+                | TextInputAction::Search
+                | TextInputAction::Send
+                | TextInputAction::Done
+        ) {
+            self.dispatch_enter_key_action(event::ElementState::Pressed, callback);
+            self.dispatch_enter_key_action(event::ElementState::Released, callback);
+        }
+    }
+
+    fn dispatch_enter_key_action<F>(&self, state: event::ElementState, callback: &mut F)
+    where
+        F: FnMut(event::Event<T>, &RootAEL),
+    {
+        callback(
+            event::Event::WindowEvent {
+                window_id: window::WindowId(WindowId),
+                event: event::WindowEvent::KeyboardInput {
+                    device_id: event::DeviceId(DeviceId(0)),
+                    event: event::KeyEvent {
+                        state,
+                        physical_key: crate::keyboard::PhysicalKey::Code(
+                            crate::keyboard::KeyCode::Enter,
+                        ),
+                        logical_key: crate::keyboard::Key::Named(
+                            crate::keyboard::NamedKey::Enter,
+                        ),
+                        location: crate::keyboard::KeyLocation::Standard,
+                        repeat: false,
+                        text: None,
+                        platform_specific: KeyEventExtra {},
+                    },
+                    is_synthetic: true,
+                },
+            },
+            self.window_target(),
+        );
+    }
