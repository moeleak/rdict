+fn valid_text_span(text: &str, span: Option<TextSpan>) -> Option<std::ops::Range<usize>> {
+    let span = span?;
+    let start = text_index_to_byte_index(text, span.start);
+    let end = text_index_to_byte_index(text, span.end);
+
+    (start < end).then_some(start..end)
+}
+
+fn text_index_to_byte_index(text: &str, index: usize) -> usize {
+    if index >= text.len() {
+        return text.len();
+    }
+
+    if text.is_char_boundary(index) {
+        index
+    } else {
+        text.char_indices()
+            .nth(index)
+            .map(|(offset, _)| offset)
+            .unwrap_or(text.len())
+    }
+}
+
+fn preedit_selection(
+    text: &str,
+    selection: TextSpan,
+    compose_region: &std::ops::Range<usize>,
+) -> Option<(usize, usize)> {
+    let start = text_index_to_byte_index(text, selection.start);
+    let end = text_index_to_byte_index(text, selection.end);
+
+    if start < compose_region.start || end > compose_region.end {
+        return None;
+    }
+
+    Some((start - compose_region.start, end - compose_region.start))
+}
